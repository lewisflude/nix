# Generate options documentation from module definitions
#
# Usage:
#   nix build .#docs
#
# This script generates documentation for Signal options.
# Note: Full option documentation requires a proper Home Manager evaluation,
# which is complex due to module dependencies. This provides a basic structure.
{
  pkgs,
  lib,
  self,
}:
let
  # Generate markdown documentation from the module structure
  optionsMarkdown = ''
    # Signal Design System Options

    This document lists the available configuration options for the Signal Design System.

    ## Core Options

    ### `theming.signal.enable`
    **Type:** boolean
    **Default:** `false`
    Enable Signal Design System theming.

    ### `theming.signal.mode`
    **Type:** enum ("light" | "dark" | "auto")
    **Default:** `"dark"`
    Color theme mode.

    ### `theming.signal.autoEnable`
    **Type:** boolean
    **Default:** `true`
    Automatically enable Signal theming for all programs that are already enabled.

    ## Application Theming

    ### Editors
    - `theming.signal.editors.helix.enable` - Helix editor
    - `theming.signal.editors.neovim.enable` - Neovim editor
    - `theming.signal.editors.vim.enable` - Vim editor
    - `theming.signal.editors.vscode.enable` - VS Code/VSCodium
    - `theming.signal.editors.emacs.enable` - Emacs
    - `theming.signal.editors.zed.enable` - Zed editor

    ### Terminals
    - `theming.signal.terminals.ghostty.enable` - Ghostty terminal
    - `theming.signal.terminals.alacritty.enable` - Alacritty terminal
    - `theming.signal.terminals.kitty.enable` - Kitty terminal
    - `theming.signal.terminals.wezterm.enable` - WezTerm terminal
    - `theming.signal.terminals.foot.enable` - Foot terminal

    ### CLI Tools
    - `theming.signal.cli.bat.enable` - bat
    - `theming.signal.cli.delta.enable` - delta git diff viewer
    - `theming.signal.cli.eza.enable` - eza file lister
    - `theming.signal.cli.fzf.enable` - fzf fuzzy finder
    - `theming.signal.cli.lazygit.enable` - lazygit
    - `theming.signal.cli.yazi.enable` - yazi file manager

    ### Desktop Environment
    - `theming.signal.gtk.enable` - GTK theme
    - `theming.signal.qt.enable` - Qt/KDE theme
    - `theming.signal.ironbar.enable` - Ironbar status bar
    - `theming.signal.fuzzel.enable` - Fuzzel launcher

    ### Desktop Compositors
    - `theming.signal.desktop.compositors.hyprland.enable` - Hyprland
    - `theming.signal.desktop.compositors.sway.enable` - Sway

    ### Window Managers
    - `theming.signal.desktop.wm.i3.enable` - i3
    - `theming.signal.desktop.wm.bspwm.enable` - bspwm
    - `theming.signal.desktop.wm.awesome.enable` - awesome

    ### Notifications
    - `theming.signal.desktop.notifications.dunst.enable` - dunst
    - `theming.signal.desktop.notifications.mako.enable` - mako
    - `theming.signal.desktop.notifications.swaync.enable` - SwayNC

    ## Brand Governance

    ### `theming.signal.brandGovernance.policy`
    **Type:** enum ("functional-override" | "separate-layer" | "integrated")
    **Default:** `"functional-override"`
    Brand governance policy for color overrides.

    ---

    *Generated by signal-nix documentation system*
  '';

  # Basic JSON structure
  optionsJson = builtins.toJSON {
    version = "1.0.0";
    description = "Signal Design System options";
    options = {
      "theming.signal.enable" = {
        type = "boolean";
        default = false;
        description = "Enable Signal Design System theming";
      };
      "theming.signal.mode" = {
        type = "enum";
        values = [
          "light"
          "dark"
          "auto"
        ];
        default = "dark";
        description = "Color theme mode";
      };
      "theming.signal.autoEnable" = {
        type = "boolean";
        default = true;
        description = "Automatically enable theming for enabled programs";
      };
    };
  };

in
{
  # JSON output
  json = pkgs.writeText "options.json" optionsJson;

  # Markdown output
  markdown = pkgs.writeText "OPTIONS.md" optionsMarkdown;

  # Combined output directory
  docs = pkgs.runCommand "signal-nix-docs" { } ''
    mkdir -p $out
    cp ${pkgs.writeText "options.json" optionsJson} $out/options.json
    cp ${pkgs.writeText "OPTIONS.md" optionsMarkdown} $out/OPTIONS.md
    echo "Signal Design System documentation" > $out/README.txt
    echo "Generated at: $(date)" >> $out/README.txt
  '';
}
