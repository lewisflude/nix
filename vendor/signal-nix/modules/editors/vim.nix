{
  signalLib,
  signalPalette,
  semantic,
  nix-colorizer,
}:
{
  config,
  lib,
  pkgs,
  ...
}:
# CONFIGURATION METHOD: raw-config (Tier 4)
# HOME-MANAGER MODULE: programs.vim.extraConfig
# UPSTREAM SCHEMA: https://vimhelp.org/syntax.txt.html
# SCHEMA VERSION: 9.0
# LAST VALIDATED: 2026-01-20
# NOTES: Vim requires Vimscript for colorscheme definition. Home-Manager provides
#        extraConfig for custom Vimscript. We generate a complete colorscheme using
#        highlight commands. No structured options exist for custom themes.
let
  inherit (lib) mkIf;
  cfg = config.theming.signal;
  themeMode = signalLib.resolveThemeMode cfg.mode;

  # Define colors using semantic bridge
  colors = {
    # Editor UI
    bg = semantic.editor "background" themeMode;
    bg_alt = semantic.editor "active-line-background" themeMode;
    fg = semantic.editor "foreground" themeMode;
    fg_alt = semantic.editor "line-number" themeMode;
    fg_dim = semantic.syntax "comment" themeMode;

    # Syntax colors
    keyword = semantic.syntax "keyword" themeMode;
    function = semantic.syntax "function" themeMode;
    string = semantic.syntax "string" themeMode;
    number = semantic.syntax "number" themeMode;
    type = semantic.syntax "type" themeMode;
    constant = semantic.syntax "constant" themeMode;
    operator = semantic.syntax "operator" themeMode;
    tag = semantic.syntax "tag" themeMode;
    preprocessing = semantic.syntax "preprocessing" themeMode;

    # Status colors
    error = semantic.status "error" themeMode;
    warning = semantic.status "warning" themeMode;
    success = semantic.status "success" themeMode;
    info = semantic.status "info" themeMode;

    # UI colors
    border = semantic.ui "panel-border" themeMode;
    selection = semantic.core "selection-bg" themeMode;
    cursor = semantic.core "cursor" themeMode;

    # VCS colors
    added = semantic.vcs "added" themeMode;
    modified = semantic.vcs "modified" themeMode;
    deleted = semantic.vcs "deleted" themeMode;
  };

  # Terminal ANSI colors using semantic bridge
  ansiColors = {
    black = semantic.terminal "ansi-black" themeMode;
    red = semantic.terminal "ansi-red" themeMode;
    green = semantic.terminal "ansi-green" themeMode;
    yellow = semantic.terminal "ansi-yellow" themeMode;
    blue = semantic.terminal "ansi-blue" themeMode;
    magenta = semantic.terminal "ansi-magenta" themeMode;
    cyan = semantic.terminal "ansi-cyan" themeMode;
    white = semantic.terminal "ansi-white" themeMode;
    bright-black = semantic.terminal "ansi-bright-black" themeMode;
    bright-red = semantic.terminal "ansi-bright-red" themeMode;
    bright-green = semantic.terminal "ansi-bright-green" themeMode;
    bright-yellow = semantic.terminal "ansi-bright-yellow" themeMode;
    bright-blue = semantic.terminal "ansi-bright-blue" themeMode;
    bright-magenta = semantic.terminal "ansi-bright-magenta" themeMode;
    bright-cyan = semantic.terminal "ansi-bright-cyan" themeMode;
    bright-white = semantic.terminal "ansi-bright-white" themeMode;
  };

  # Check if vim should be themed
  shouldTheme = signalLib.shouldThemeApp "vim" [
    "editors"
    "vim"
  ] cfg config;
in
{
  config = mkIf (cfg.enable && shouldTheme) {
    programs.vim.extraConfig = ''
      " Signal Vim Colorscheme
      " Generated by signal-nix

      set background=${if cfg.mode == "light" then "light" else "dark"}

      highlight clear
      if exists("syntax_on")
        syntax reset
      endif

      let g:colors_name = "signal"

      " Editor colors
      highlight Normal guifg=${colors.fg.hex} guibg=${colors.bg.hex}
      highlight LineNr guifg=${colors.fg_alt.hex} guibg=${colors.bg.hex}
      highlight CursorLineNr guifg=${colors.fg.hex} guibg=${colors.bg_alt.hex}
      highlight CursorLine guibg=${colors.bg_alt.hex}
      highlight CursorColumn guibg=${colors.bg_alt.hex}
      highlight ColorColumn guibg=${colors.bg_alt.hex}
      highlight Visual guibg=${colors.selection.hex}
      highlight VisualNOS guibg=${colors.selection.hex}
      highlight Search guifg=${colors.bg.hex} guibg=${colors.warning.hex}
      highlight IncSearch guifg=${colors.bg.hex} guibg=${colors.success.hex}
      highlight MatchParen guifg=${colors.cursor.hex} guibg=${colors.selection.hex} gui=bold

      " UI Elements
      highlight StatusLine guifg=${colors.fg.hex} guibg=${colors.bg_alt.hex}
      highlight StatusLineNC guifg=${colors.fg_dim.hex} guibg=${colors.bg_alt.hex}
      highlight VertSplit guifg=${colors.border.hex} guibg=${colors.bg.hex}
      highlight TabLine guifg=${colors.fg_dim.hex} guibg=${colors.bg_alt.hex}
      highlight TabLineFill guibg=${colors.bg_alt.hex}
      highlight TabLineSel guifg=${colors.fg.hex} guibg=${colors.bg.hex}
      highlight Pmenu guifg=${colors.fg.hex} guibg=${colors.bg_alt.hex}
      highlight PmenuSel guifg=${colors.bg.hex} guibg=${colors.cursor.hex}
      highlight PmenuSbar guibg=${colors.bg_alt.hex}
      highlight PmenuThumb guibg=${colors.fg_dim.hex}
      highlight Folded guifg=${colors.fg_dim.hex} guibg=${colors.bg_alt.hex}
      highlight FoldColumn guifg=${colors.fg_dim.hex} guibg=${colors.bg.hex}

      " Messages
      highlight ErrorMsg guifg=${colors.error.hex}
      highlight WarningMsg guifg=${colors.warning.hex}
      highlight ModeMsg guifg=${colors.success.hex}
      highlight MoreMsg guifg=${colors.info.hex}
      highlight Question guifg=${colors.info.hex}

      " Syntax highlighting
      highlight Comment guifg=${colors.fg_dim.hex} gui=italic
      highlight Constant guifg=${colors.constant.hex}
      highlight String guifg=${colors.string.hex}
      highlight Character guifg=${colors.string.hex}
      highlight Number guifg=${colors.number.hex}
      highlight Boolean guifg=${colors.constant.hex}
      highlight Float guifg=${colors.number.hex}

      highlight Identifier guifg=${colors.fg.hex}
      highlight Function guifg=${colors.function.hex}

      highlight Statement guifg=${colors.keyword.hex}
      highlight Conditional guifg=${colors.keyword.hex}
      highlight Repeat guifg=${colors.keyword.hex}
      highlight Label guifg=${colors.keyword.hex}
      highlight Operator guifg=${colors.operator.hex}
      highlight Keyword guifg=${colors.keyword.hex}
      highlight Exception guifg=${colors.error.hex}

      highlight PreProc guifg=${colors.preprocessing.hex}
      highlight Include guifg=${colors.preprocessing.hex}
      highlight Define guifg=${colors.preprocessing.hex}
      highlight Macro guifg=${colors.preprocessing.hex}
      highlight PreCondit guifg=${colors.preprocessing.hex}

      highlight Type guifg=${colors.type.hex}
      highlight StorageClass guifg=${colors.keyword.hex}
      highlight Structure guifg=${colors.type.hex}
      highlight Typedef guifg=${colors.type.hex}

      highlight Special guifg=${colors.info.hex}
      highlight SpecialChar guifg=${colors.info.hex}
      highlight Tag guifg=${colors.tag.hex}
      highlight Delimiter guifg=${colors.fg_alt.hex}
      highlight SpecialComment guifg=${colors.info.hex} gui=italic
      highlight Debug guifg=${colors.error.hex}

      highlight Underlined guifg=${colors.cursor.hex} gui=underline
      highlight Ignore guifg=${colors.fg_dim.hex}
      highlight Error guifg=${colors.error.hex} guibg=${colors.bg.hex}
      highlight Todo guifg=${colors.keyword.hex} guibg=${colors.bg.hex} gui=bold

      " Diff colors
      highlight DiffAdd guifg=${colors.added.hex} guibg=${colors.bg_alt.hex}
      highlight DiffChange guifg=${colors.modified.hex} guibg=${colors.bg_alt.hex}
      highlight DiffDelete guifg=${colors.deleted.hex} guibg=${colors.bg_alt.hex}
      highlight DiffText guifg=${colors.modified.hex} guibg=${colors.selection.hex}

      " Spell checking
      highlight SpellBad guisp=${colors.error.hex} gui=undercurl
      highlight SpellCap guisp=${colors.warning.hex} gui=undercurl
      highlight SpellLocal guisp=${colors.info.hex} gui=undercurl
      highlight SpellRare guisp=${colors.warning.hex} gui=undercurl

      " Terminal colors (for :terminal)
      let g:terminal_ansi_colors = [
      \ '${ansiColors.black.hex}',
      \ '${ansiColors.red.hex}',
      \ '${ansiColors.green.hex}',
      \ '${ansiColors.yellow.hex}',
      \ '${ansiColors.blue.hex}',
      \ '${ansiColors.magenta.hex}',
      \ '${ansiColors.cyan.hex}',
      \ '${ansiColors.white.hex}',
      \ '${ansiColors.bright-black.hex}',
      \ '${ansiColors.bright-red.hex}',
      \ '${ansiColors.bright-green.hex}',
      \ '${ansiColors.bright-yellow.hex}',
      \ '${ansiColors.bright-blue.hex}',
      \ '${ansiColors.bright-magenta.hex}',
      \ '${ansiColors.bright-cyan.hex}',
      \ '${ansiColors.bright-white.hex}',
      \ ]
    '';
  };
}
