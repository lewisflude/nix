{
  signalLib,
  signalPalette,
  semantic,
  nix-colorizer,
}:
{
  config,
  lib,
  pkgs,
  ...
}:
# CONFIGURATION METHOD: raw-config (Tier 4)
# HOME-MANAGER MODULE: programs.emacs.extraConfig
# UPSTREAM SCHEMA: https://www.gnu.org/software/emacs/manual/html_node/emacs/Custom-Themes.html
# SCHEMA VERSION: 29.1
# LAST VALIDATED: 2026-01-20
# NOTES: Emacs requires Elisp for theme definition. Home-Manager provides extraConfig
#        for custom Elisp. We generate a custom theme using deftheme and custom-theme-set-faces.
let
  inherit (lib) mkIf;
  cfg = config.theming.signal;
  themeMode = signalLib.resolveThemeMode cfg.mode;

  # Define colors using semantic bridge
  colors = {
    # Editor UI
    bg = semantic.editor "background" themeMode;
    bg-alt = semantic.editor "active-line-background" themeMode;
    bg-highlight = semantic.core "selection-bg" themeMode;
    fg = semantic.editor "foreground" themeMode;
    fg-alt = semantic.editor "line-number" themeMode;
    fg-dim = semantic.syntax "comment" themeMode;
    border = semantic.ui "panel-border" themeMode;

    # Syntax colors
    keyword = semantic.syntax "keyword" themeMode;
    function = semantic.syntax "function" themeMode;
    string = semantic.syntax "string" themeMode;
    number = semantic.syntax "number" themeMode;
    type = semantic.syntax "type" themeMode;
    constant = semantic.syntax "constant" themeMode;
    operator = semantic.syntax "operator" themeMode;
    tag = semantic.syntax "tag" themeMode;
    preprocessing = semantic.syntax "preprocessing" themeMode;

    # Status colors
    error = semantic.status "error" themeMode;
    warning = semantic.status "warning" themeMode;
    success = semantic.status "success" themeMode;
    info = semantic.status "info" themeMode;

    # VCS colors
    added = semantic.vcs "added" themeMode;
    modified = semantic.vcs "modified" themeMode;
    deleted = semantic.vcs "deleted" themeMode;

    # UI colors
    cursor = semantic.core "cursor" themeMode;
    selection = semantic.core "selection-bg" themeMode;
    focus = semantic.core "focus" themeMode;
  };

  # Check if emacs should be themed
  shouldTheme = signalLib.shouldThemeApp "emacs" [
    "editors"
    "emacs"
  ] cfg config;
in
{
  config = mkIf (cfg.enable && shouldTheme) {
    programs.emacs.extraConfig = ''
      ;;; Signal Emacs Theme
      ;;; Generated by signal-nix

      (deftheme signal
        "Signal Design System theme for Emacs")

      (let ((class '((class color) (min-colors 89))))
        (custom-theme-set-faces
         'signal

         ;; Base faces
         `(default ((,class (:foreground "${colors.fg.hex}" :background "${colors.bg.hex}"))))
         `(cursor ((,class (:background "${colors.cursor.hex}"))))
         `(region ((,class (:background "${colors.selection.hex}"))))
         `(highlight ((,class (:background "${colors.bg-alt.hex}"))))
         `(hl-line ((,class (:background "${colors.bg-alt.hex}"))))
         `(fringe ((,class (:background "${colors.bg.hex}" :foreground "${colors.fg-dim.hex}"))))
         `(vertical-border ((,class (:foreground "${colors.border.hex}"))))
         `(window-divider ((,class (:foreground "${colors.border.hex}"))))
         `(window-divider-first-pixel ((,class (:foreground "${colors.border.hex}"))))
         `(window-divider-last-pixel ((,class (:foreground "${colors.border.hex}"))))

         ;; Mode line
         `(mode-line ((,class (:background "${colors.bg-alt.hex}" :foreground "${colors.fg.hex}" :box (:line-width 2 :color "${colors.border.hex}")))))
         `(mode-line-inactive ((,class (:background "${colors.bg.hex}" :foreground "${colors.fg-dim.hex}" :box (:line-width 2 :color "${colors.border.hex}")))))
         `(mode-line-buffer-id ((,class (:foreground "${colors.function.hex}" :weight bold))))
         `(mode-line-emphasis ((,class (:foreground "${colors.success.hex}" :weight bold))))

         ;; Line numbers
         `(line-number ((,class (:foreground "${colors.fg-dim.hex}" :background "${colors.bg.hex}"))))
         `(line-number-current-line ((,class (:foreground "${colors.fg-alt.hex}" :background "${colors.bg-alt.hex}"))))

         ;; Font lock (syntax highlighting)
         `(font-lock-comment-face ((,class (:foreground "${colors.fg-dim.hex}" :slant italic))))
         `(font-lock-doc-face ((,class (:foreground "${colors.fg-dim.hex}" :slant italic))))
         `(font-lock-string-face ((,class (:foreground "${colors.string.hex}"))))
         `(font-lock-keyword-face ((,class (:foreground "${colors.keyword.hex}" :weight bold))))
         `(font-lock-builtin-face ((,class (:foreground "${colors.operator.hex}"))))
         `(font-lock-function-name-face ((,class (:foreground "${colors.function.hex}"))))
         `(font-lock-variable-name-face ((,class (:foreground "${colors.fg.hex}"))))
         `(font-lock-type-face ((,class (:foreground "${colors.type.hex}"))))
         `(font-lock-constant-face ((,class (:foreground "${colors.constant.hex}"))))
         `(font-lock-warning-face ((,class (:foreground "${colors.warning.hex}" :weight bold))))
         `(font-lock-preprocessor-face ((,class (:foreground "${colors.preprocessing.hex}"))))

         ;; Search
         `(isearch ((,class (:foreground "${colors.bg.hex}" :background "${colors.warning.hex}" :weight bold))))
         `(lazy-highlight ((,class (:foreground "${colors.bg.hex}" :background "${colors.info.hex}"))))
         `(match ((,class (:foreground "${colors.bg.hex}" :background "${colors.focus.hex}"))))

         ;; Links
         `(link ((,class (:foreground "${colors.function.hex}" :underline t))))
         `(link-visited ((,class (:foreground "${colors.keyword.hex}" :underline t))))

         ;; Minibuffer
         `(minibuffer-prompt ((,class (:foreground "${colors.function.hex}" :weight bold))))

         ;; Messages
         `(error ((,class (:foreground "${colors.error.hex}" :weight bold))))
         `(warning ((,class (:foreground "${colors.warning.hex}" :weight bold))))
         `(success ((,class (:foreground "${colors.success.hex}" :weight bold))))

         ;; Company (completion)
         `(company-tooltip ((,class (:background "${colors.bg-alt.hex}" :foreground "${colors.fg.hex}"))))
         `(company-tooltip-selection ((,class (:background "${colors.selection.hex}" :foreground "${colors.fg.hex}"))))
         `(company-tooltip-common ((,class (:foreground "${colors.function.hex}" :weight bold))))
         `(company-tooltip-annotation ((,class (:foreground "${colors.fg-dim.hex}"))))
         `(company-scrollbar-bg ((,class (:background "${colors.bg-alt.hex}"))))
         `(company-scrollbar-fg ((,class (:background "${colors.border.hex}"))))

         ;; Org mode
         `(org-level-1 ((,class (:foreground "${colors.function.hex}" :weight bold :height 1.3))))
         `(org-level-2 ((,class (:foreground "${colors.info.hex}" :weight bold :height 1.2))))
         `(org-level-3 ((,class (:foreground "${colors.success.hex}" :weight bold :height 1.1))))
         `(org-level-4 ((,class (:foreground "${colors.type.hex}" :weight bold))))
         `(org-level-5 ((,class (:foreground "${colors.warning.hex}" :weight bold))))
         `(org-level-6 ((,class (:foreground "${colors.keyword.hex}" :weight bold))))
         `(org-level-7 ((,class (:foreground "${colors.error.hex}" :weight bold))))
         `(org-level-8 ((,class (:foreground "${colors.fg-alt.hex}" :weight bold))))
         `(org-link ((,class (:foreground "${colors.function.hex}" :underline t))))
         `(org-document-title ((,class (:foreground "${colors.function.hex}" :weight bold :height 1.4))))
         `(org-document-info ((,class (:foreground "${colors.info.hex}"))))
         `(org-document-info-keyword ((,class (:foreground "${colors.fg-dim.hex}"))))
         `(org-code ((,class (:foreground "${colors.string.hex}" :background "${colors.bg-alt.hex}"))))
         `(org-verbatim ((,class (:foreground "${colors.warning.hex}"))))
         `(org-block ((,class (:background "${colors.bg-alt.hex}"))))
         `(org-block-begin-line ((,class (:foreground "${colors.fg-dim.hex}" :background "${colors.bg-alt.hex}"))))
         `(org-block-end-line ((,class (:foreground "${colors.fg-dim.hex}" :background "${colors.bg-alt.hex}"))))
         `(org-meta-line ((,class (:foreground "${colors.fg-dim.hex}"))))
         `(org-date ((,class (:foreground "${colors.info.hex}" :underline t))))
         `(org-todo ((,class (:foreground "${colors.error.hex}" :weight bold))))
         `(org-done ((,class (:foreground "${colors.success.hex}" :weight bold))))
         `(org-special-keyword ((,class (:foreground "${colors.keyword.hex}"))))
         `(org-table ((,class (:foreground "${colors.fg-alt.hex}"))))

         ;; Dired
         `(dired-directory ((,class (:foreground "${colors.function.hex}" :weight bold))))
         `(dired-symlink ((,class (:foreground "${colors.info.hex}"))))
         `(dired-marked ((,class (:foreground "${colors.success.hex}" :weight bold))))
         `(dired-flagged ((,class (:foreground "${colors.error.hex}" :weight bold))))

         ;; Diff
         `(diff-added ((,class (:foreground "${colors.added.hex}" :background "${colors.bg-alt.hex}"))))
         `(diff-removed ((,class (:foreground "${colors.deleted.hex}" :background "${colors.bg-alt.hex}"))))
         `(diff-changed ((,class (:foreground "${colors.modified.hex}" :background "${colors.bg-alt.hex}"))))
         `(diff-header ((,class (:foreground "${colors.fg-alt.hex}" :background "${colors.bg-alt.hex}"))))
         `(diff-file-header ((,class (:foreground "${colors.function.hex}" :weight bold))))
         `(diff-refine-added ((,class (:foreground "${colors.added.hex}" :background "${colors.selection.hex}"))))
         `(diff-refine-removed ((,class (:foreground "${colors.deleted.hex}" :background "${colors.selection.hex}"))))

         ;; Magit
         `(magit-header-line ((,class (:foreground "${colors.function.hex}" :weight bold))))
         `(magit-section-heading ((,class (:foreground "${colors.function.hex}" :weight bold))))
         `(magit-section-highlight ((,class (:background "${colors.bg-alt.hex}"))))
         `(magit-diff-added ((,class (:foreground "${colors.added.hex}" :background "${colors.bg-alt.hex}"))))
         `(magit-diff-removed ((,class (:foreground "${colors.deleted.hex}" :background "${colors.bg-alt.hex}"))))
         `(magit-diff-added-highlight ((,class (:foreground "${colors.added.hex}" :background "${colors.selection.hex}"))))
         `(magit-diff-removed-highlight ((,class (:foreground "${colors.deleted.hex}" :background "${colors.selection.hex}"))))
         `(magit-diff-context ((,class (:foreground "${colors.fg-alt.hex}" :background "${colors.bg.hex}"))))
         `(magit-diff-context-highlight ((,class (:foreground "${colors.fg-alt.hex}" :background "${colors.bg-alt.hex}"))))
         `(magit-branch-local ((,class (:foreground "${colors.function.hex}"))))
         `(magit-branch-remote ((,class (:foreground "${colors.success.hex}"))))
         `(magit-tag ((,class (:foreground "${colors.type.hex}"))))
         `(magit-hash ((,class (:foreground "${colors.fg-dim.hex}"))))

         ;; Show paren
         `(show-paren-match ((,class (:background "${colors.selection.hex}" :foreground "${colors.focus.hex}" :weight bold))))
         `(show-paren-mismatch ((,class (:background "${colors.error.hex}" :foreground "${colors.bg.hex}" :weight bold))))))

      (provide-theme 'signal)

      ;; Load the theme
      (load-theme 'signal t)
    '';
  };
}
